<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3 border-end bg-light">
            <div class="p-4">
                <h3>Filters</h3>
                <p>SEARCH FILTERS COMING UP</p>
                <div>
                    <div>
                        <p>Time filter</p>
                    </div>
                    <div>
                        <form method="get" id="filterForm">
                            <p>Choose Capacity</p>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedCapacities" value="small"
                                       onchange="this.form.submit()" @(Model.SelectedCapacities.Contains("small") ? "checked" : "")>
                                <label class="form-check-label">0-25</label>
                            </div>
    
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedCapacities" value="medium"
                                       onchange="this.form.submit()" @(Model.SelectedCapacities.Contains("medium") ? "checked" : "")>
                                <label class="form-check-label">25-50</label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedCapacities" value="large"
                                       onchange="this.form.submit()" @(Model.SelectedCapacities.Contains("large") ? "checked" : "")>
                                <label class="form-check-label">50-75</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedCapacities" value="xlarge"
                                       onchange="this.form.submit()" @(Model.SelectedCapacities.Contains("xlarge") ? "checked" : "")>
                                <label class="form-check-label">75+</label>
                            </div>
                        </form>
                    </div>
                    <div>
                        <form method="get" id="filterForm">
                            <p>Choose Equipment</p>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedCapacities" value="Projector"
                                       onchange="this.form.submit()" @(Model.SelectedEquipment.Contains("Projector") ? "checked" : "")>
                                <label class="form-check-label">0-25</label>
                            </div>
    
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedCapacities" value="medium"
                                       onchange="this.form.submit()" @(Model.SelectedEquipment.Contains("Whiteboard") ? "checked" : "")>
                                <label class="form-check-label">25-50</label>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="SelectedCapacities" value="large"
                                       onchange="this.form.submit()" @(Model.SelectedEquipment.Contains("Microphone") ? "checked" : "")>
                                <label class="form-check-label">50-75</label>
                            </div>                     
                        </form>
                        
                    </div>
                </div>
            </div>
        </div>

       
        <div class="col-md-9">
            <div class="d-flex align-items-center justify-content-between mb-4 ps-3 pe-5">
                <h1 class="display-4 mb-0">Meeting Rooms</h1>
                <div style="width: 100%; max-width: 500px;">
                    <form class="d-flex" method="post" asp-page-handler="SearchTerm">
                        <div class="input-group">
                            <input class="form-control form-control-lg" type="search" asp-for="SearchTerm" placeholder="Search member ID to view bookings" aria-label="Search">
                            <button class="btn btn-primary px-4" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="index-grid d-flex flex-wrap justify-content-start gap-3">
                @foreach (var room in Model.MeetingRooms)
                {
                    <div class="card mb-3 shadow-sm" style="flex: 0 1 500px;">
                        <div class="row g-0 align-items-center">
                            <div class="col-md-4">
                                <img src="~/images/room.jpg" class="img-fluid rounded-start" alt="Room Image"
                                     style="object-fit: cover; height: 200px;" />
                            </div>
                            <div class="col-md-8">
                                <div class="card-body position-relative">
                                    <div class="position-absolute top-0 end-0 p-3 text-muted">
                                        <i class="fa-solid fa-users"></i> @room.Capacity
                                    </div>
                                    <h5 class="card-title pe-5">@room.Name </h5>

                                    <p class="card-text">
                                        <strong>Equipment:</strong>
                                        @if (room.Equipment != null && room.Equipment.Any())
                                        {
                                            @string.Join(", ", room.Equipment)
                                        }
                                        else
                                        {
                                            <span>None</span>
                                        }
                                    </p>

                                    <p class="card-text text-truncate" style="max-height: 50px;">@room.Description</p>
                                    <a asp-page="./CreateBooking" asp-route-id="@room.RoomId" class="btn btn-primary">Book Now</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
   