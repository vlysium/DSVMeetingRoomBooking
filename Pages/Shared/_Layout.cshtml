<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta robots="noindex, nofollow" />
  <title>@ViewData["Title"] - DSVMeetingRoomBooking</title>
  <script type="importmap"></script>
  <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/index-page.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/booking.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/DSVMeetingRoomBooking.styles.css" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

</head>
<body>
  <header class="header">
    @* <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow px-3 py-4">
      <div class="collapse navbar-collapse">
        <a class="navbar-brand" asp-page="/Index">DSVMeetingRoomBooking</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
            aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
          <ul class="navbar-nav flex-grow-1">
            <li class="nav-item">
              <a class="nav-link text-dark fw-bold" asp-page="/Bookings">Bookings</a>
            </li>
          </ul>
        </div>
      </div>
    </nav> *@
    <nav class="navbar navbar-expand-lg border-bottom">
      <div class="container-fluid gap-4">
        <a class="logo navbar-brand" asp-page="/Index">
          <span>DSV</span>
          <span>Meeting Room Booking</span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown" aria-controls="navbarNavDropdown" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNavDropdown">
          <ul class="navbar-nav">
            <li class="nav-item">
              <a class="nav-link fw-bold" asp-page="/Index">Home</a>
            </li>
            <li class="nav-item">
              <a class="nav-link fw-bold" asp-page="/Bookings">Bookings</a>
            </li>
          </ul>
        </div>
      </div>
    </nav>
  </header>
  <div class="">
    <main role="main">
      @RenderBody()
    </main>
  </div>

    <footer class="border-top py-3 text-white">
        <div class="container-fluid ps-4">
            <span>©<small>2026</small> <span class="contrast-color">DSV</span><small> Room Booking Service</small></span>
        </div>
    </footer>

  <script src="~/lib/jquery/dist/jquery.min.js"></script>
  <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
  <script src="~/js/site.js" asp-append-version="true"></script>

  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
